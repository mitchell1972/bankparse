# HMRC Developer Hub credentials for LOCAL DEVELOPMENT.
#
# 1. Copy this file to `.env.hmrc` (gitignored) — DO NOT commit your real values.
# 2. Fill in the two SECRET values from
#    https://developer.service.hmrc.gov.uk/developer/applications.
# 3. Load it before running the journey:
#       export $(grep -v '^#' .env.hmrc | xargs)
#    or use direnv / dotenv to autoload.
# 4. Verify everything is wired correctly:
#       python scripts/hmrc_dev_hub_check.py
#
# The defaults below are correct for SANDBOX local development against
# `https://test-api.service.hmrc.gov.uk`. Production deploys live on Railway
# and use a different secret set; do not put production keys in this file.

# --- The two values you have to fill in from the Developer Hub ---
# Confirmed client ID for the existing sandbox app
# `BankScan AI` (id c16a75dc-378d-4171-a2ca-4a4f1cd068b0) as of 2026-05-24.
# Verify on the Credentials page; HMRC may rotate it if the app is recreated.
HMRC_CLIENT_ID=UhqfKGKZlsk3dBHxqW4gkZVT2iG5
# Reveal-once at creation. If you no longer have it, generate a new one at
# https://developer.service.hmrc.gov.uk/developer/applications/c16a75dc-378d-4171-a2ca-4a4f1cd068b0/client-secrets
HMRC_CLIENT_SECRET=

# --- Everything below should be left as-is for local sandbox work ---

# Sandbox environment.
HMRC_ENV=sandbox

# Local callback URL — MUST also be added as a redirect URI on your
# Developer Hub application page (https://developer.service.hmrc.gov.uk/
# developer/applications/<your-app-id> → Manage redirect URIs).
HMRC_REDIRECT_URI=http://127.0.0.1:8000/api/hmrc/callback

# Vendor identity sent in fraud-prevention headers. Keep stable across
# environments so HMRC can attribute traffic.
HMRC_VENDOR_PRODUCT_NAME=BankScan AI
HMRC_VENDOR_SOFTWARE_NAME=bankscan-ai

# AES-GCM key for encrypting OAuth tokens at rest. The value below is a
# throwaway 32-byte key safe for LOCAL dev only — regenerate for any
# deploy that handles real user tokens:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
HMRC_TOKEN_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
