{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "api/debug.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/debug",
      "dest": "api/debug.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
