{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/debug.py": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/debug", "destination": "/api/debug.py" },
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "headers": [
    {
      "source": "/blog/:path*/:asset(og-image|hero-image|infographic)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800, immutable" }]
    },
    {
      "source": "/blog/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }]
    },
    {
      "source": "/tools/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }]
    }
  ]
}
